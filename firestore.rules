rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Products: public may read only ACTIVE (published) products — the storefront
    // queries where('status','==','active'). Admins read/write everything,
    // including hidden and archived items. Only admins can create/edit/delete.
    match /products/{productId} {
      allow read:  if isAdmin() || resource.data.status == 'active';
      allow write: if isAdmin();
    }

    // Orders. Guest order tracking: any authenticated session (including a
    // silent anonymous sign-in — no Google account required) may read orders,
    // because the client looks them up by order number + email, which are the
    // credentials a customer must know. Admins read all and update. The
    // status-history subcollection stays admin-only.
    match /orders/{orderId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();

      match /{sub=**} {
        allow read:  if isAdmin();
        allow write: if isAdmin();
      }
    }

    // Store config (GCash details, thresholds, admin reference list).
    // Public read so the storefront can use it; admin-only write.
    match /config/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Global store settings — currently the single site-wide coupon
    // (settings/globalCoupon). Public read so the storefront can show/validate
    // it; admins manage it. A signed-in order placement may bump ONLY the
    // usage counter by exactly +1 (so coupon redemptions can be counted
    // without a Cloud Function) — it can change nothing else.
    match /settings/{doc} {
      allow read:  if true;
      allow write: if isAdmin();
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentUses'])
                    && request.resource.data.currentUses is int
                    && request.resource.data.currentUses == resource.data.currentUses + 1;
    }

    // Self-assessment responses. Any signed-in session (incl. anonymous) may
    // record their own questionnaire; only admins can read/manage them.
    match /assessments/{id} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // Specialist consultation bookings. Any signed-in session (incl. anonymous)
    // may book. Admins read/manage all; the booking owner may read their own
    // (signed-in email matches the booking email) to track its status. Only
    // admins can update/delete.
    match /consultations/{id} {
      allow create: if request.auth != null;
      allow read:   if isAdmin() ||
                    (request.auth != null && request.auth.token.email == resource.data.email);
      allow update, delete: if isAdmin();
    }
  }
}
