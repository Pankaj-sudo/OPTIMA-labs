rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images: public read (they appear on the storefront),
    // admin-only write, capped at 5 MB and images only.
    match /product_images/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Certificates of Analysis: public read, admin-only write.
    match /coa/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.admin == true
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Payment proofs: any signed-in user may upload (image, <5MB). Read is
    // allowed for any signed-in user so the uploader can call getDownloadURL()
    // to attach the receipt URL to their order; paths are random order IDs and
    // the admin dashboard is where they're actually viewed.
    match /payment_proofs/{file} {
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read:  if request.auth != null;
    }

    // Consultation payment receipts: any signed-in session (incl. anonymous)
    // may upload an image OR PDF, <10MB. Read for signed-in users so the
    // uploader can attach a download URL; admins view them in the dashboard.
    match /consultation_proofs/{file} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
      allow read:  if request.auth != null;
    }

    // Self-assessment lab results (optional): any signed-in session (incl.
    // anonymous) may upload an image OR PDF, <10MB. Read for signed-in users.
    match /lab_results/{file} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
      allow read:  if request.auth != null;
    }

    match /{allPaths=**} { allow read, write: if false; }
  }
}
