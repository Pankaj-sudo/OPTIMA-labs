{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Content-Type", "value": "text/css; charset=utf-8" }]
    }
  ]
}
